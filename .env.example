# ---------------------------------------------------------------------------
# PollForge environment configuration
# Copy this file to .env and fill in real values before deploying.
# ---------------------------------------------------------------------------

# PostgreSQL connection string used by Prisma and the app.
# When running via docker compose, the host is the "db" service name.
DATABASE_URL="postgresql://pollforge:pollforge@db:5432/pollforge?schema=public"

# Used only by docker compose to initialise the Postgres container.
POSTGRES_USER=pollforge
POSTGRES_PASSWORD=pollforge
POSTGRES_DB=pollforge

# Secret used to sign session JWTs and other tokens.
# Generate with: openssl rand -base64 48
AUTH_SECRET="change-me-please-generate-a-long-random-string"

# Public base URL of the app (used to build invite/share links).
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Node environment
NODE_ENV=production
